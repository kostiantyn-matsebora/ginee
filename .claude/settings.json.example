{
  "_comment": "ginee context-economy gate — Layer 1 (Claude Code PostToolUse hook). Copy this file to .claude/settings.json in your local checkout to activate. The hook runs scripts/context-economy-check.ps1 after each Edit/Write/MultiEdit and surfaces a JSON summary as additional context. Requires pwsh 7+ on PATH.",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File scripts/context-economy-check.ps1 -ClaudeHook -Json",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
