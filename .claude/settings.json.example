{
  "_comment": "ginee compliance — Copy this file to .claude/settings.json to activate. PostToolUse hook surfaces context-economy summary; statusLine surfaces compliance state per the playbook tactic 4 (#140). Requires pwsh 7+ on PATH. Opt out: local/framework.config.yaml § compliance.disabled: [compliance-statusline].",
  "statusLine": {
    "type": "command",
    "command": "pwsh -NoProfile -File adapters/claude/statusline.ps1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File scripts/context-economy-check.ps1 -ClaudeHook -Json",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
