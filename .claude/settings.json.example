{
  "_comment": "ginee compliance hooks — Copy this file to .claude/settings.json in your local checkout to activate. (1) PostToolUse: context-economy gate surfaces a JSON summary after each Edit/Write/MultiEdit. (2) PreToolUse: blocks Edit/Write/MultiEdit on the 5 violation classes per the compliance playbook (#135 tactic 2). Both require pwsh 7+ on PATH. Bypass per invocation: SKIP_GINEE_COMPLIANCE=1; opt out repo-wide: local/framework.config.yaml § compliance.disabled: [pretooluse-edit-hook].",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File adapters/claude/hooks/pre-tool-use-edit.ps1",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File scripts/context-economy-check.ps1 -ClaudeHook -Json",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
