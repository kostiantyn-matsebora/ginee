{
  "_comment": "ginee compliance hooks — Copy this file to .claude/settings.json in your local checkout to activate. (1) PreToolUse on Edit|Write|MultiEdit (T2 #138): blocks 5 violation classes per the compliance playbook. (2) PreToolUse on Bash (T3 #139): blocks 4 destructive shell-command patterns. (3) PostToolUse: context-economy gate surfaces a JSON summary after each Edit/Write/MultiEdit. Each requires pwsh 7+ on PATH. Bypass per invocation: SKIP_GINEE_COMPLIANCE=1; opt out repo-wide: local/framework.config.yaml § compliance.disabled.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File adapters/claude/hooks/pre-tool-use-edit.ps1",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File adapters/claude/hooks/pre-tool-use-bash.ps1",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File scripts/context-economy-check.ps1 -ClaudeHook -Json",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
